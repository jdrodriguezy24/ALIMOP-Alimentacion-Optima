<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Perfil - ALIMOP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="../CSS/styleProveedor/perfilProveedor.css">
</head>
<body>
    <div class="container-fluid p-0 registro-proveedor-wrapper">
        <header class="bg-light py-3 border-bottom">
            <div class="container d-flex justify-content-between align-items-center">
                <h1 class="h3 mb-0">Mi Perfil - Proveedor</h1>
                <a href="/inicio/<%= usuario.idProveedor %>" class="btn btn-outline-primary">Volver al Inicio</a>
            </div>
        </header>
        
        <main class="d-flex align-items-center justify-content-center">
            <section class="w-100">
                <div class="row justify-content-center">
                    <div class="col-md-8 col-lg-6">
                        <div class="card shadow-sm">
                            <div class="card-body p-5">
                                <div class="text-center mb-4">
                                    <img src="/img/IconosMenu/cuenta.png" alt="Foto de perfil" class="rounded-circle" style="width: 100px; height: 100px; object-fit: cover;">
                                </div>
                                
                                <h2 class="card-title text-center mb-4">Mi Perfil</h2>
                                
                                <% if (mensaje) { %>
                                    <div class="alert <%= mensaje.includes('Error') ? 'alert-danger' : 'alert-success' %>" role="alert">
                                        <%= mensaje %>
                                    </div>
                                <% } %>
                                
                                <form class="perfil-form" action="/perfilProveedor/<%= usuario.idProveedor %>/actualizar" method="POST">
                                    <!-- Información del Propietario -->
                                    <h5 class="text-success mb-3">Datos del Propietario</h5>
                                    
                                    <div class="mb-3 form-group">
                                        <label for="nombrePropietario" class="form-label">Nombre del Propietario</label>
                                        <div class="input-group">
                                            <input type="text" id="nombrePropietario" name="nombrePropietario" class="form-control" value="<%= usuario.nombreProveedor %>" readonly required>
                                            <button type="button" class="btn btn-outline-success btn-editar" onclick="habilitarEdicion(this)">Editar</button>
                                        </div>
                                    </div>

                                    <div class="mb-3 form-group">
                                        <label for="correo" class="form-label">Correo Electrónico</label>
                                        <div class="input-group">
                                            <input type="email" id="correo" name="correo" class="form-control" value="<%= usuario.correo %>" readonly required>
                                            <button type="button" class="btn btn-outline-success btn-editar" onclick="habilitarEdicion(this)">Editar</button>
                                        </div>
                                    </div>

                                    <div class="mb-4 form-group">
                                        <label for="contrasena" class="form-label">Contraseña</label>
                                        <div class="input-group">
                                            <input type="password" id="contrasena" name="contrasena" class="form-control" value="<%= usuario.contrasena %>" readonly required>
                                            <button type="button" class="btn btn-outline-success btn-editar" onclick="habilitarEdicion(this)">Editar</button>
                                        </div>
                                    </div>

                                    <!-- Información del Establecimiento -->
                                    <h5 class="text-success mb-3">Datos del Establecimiento</h5>
                                    
                                    <div class="mb-3 form-group">
                                        <label for="nombreEstablecimiento" class="form-label">Nombre del Establecimiento</label>
                                        <div class="input-group">
                                            <input type="text" id="nombreEstablecimiento" name="nombreEstablecimiento" class="form-control" value="<%= usuario.nombreEstablecimiento %>" readonly required>
                                            <button type="button" class="btn btn-outline-success btn-editar" onclick="habilitarEdicion(this)">Editar</button>
                                        </div>
                                    </div>

                                    <div class="mb-3 form-group">
                                        <label for="direccionEstablecimiento" class="form-label">Dirección</label>
                                        <div class="input-group">
                                            <input type="text" id="direccionEstablecimiento" name="direccionEstablecimiento" class="form-control" value="<%= usuario.direccion %>" readonly required>
                                            <button type="button" class="btn btn-outline-success btn-editar" onclick="habilitarEdicion(this)">Editar</button>
                                        </div>
                                    </div>

                                    <div class="mb-4 form-group">
                                        <label for="telefonoEstablecimiento" class="form-label">Teléfono</label>
                                        <div class="input-group">
                                            <input type="tel" id="telefonoEstablecimiento" name="telefonoEstablecimiento" class="form-control" value="<%= usuario.telefono %>" readonly required>
                                            <button type="button" class="btn btn-outline-success btn-editar" onclick="habilitarEdicion(this)">Editar</button>
                                        </div>
                                    </div>

                                    <div class="d-grid gap-2 mb-3">
                                        <button type="submit" class="btn btn-success btn-lg">Guardar Cambios</button>
                                    </div>
                                </form>
                                
                                <div class="d-grid">
                                    <a href="/perfilProveedor/<%= usuario.idProveedor %>/eliminar" class="btn btn-danger" onclick="return confirm('¿Estás seguro de que quieres eliminar tu cuenta? Esta acción no se puede deshacer.')">
                                        Eliminar Cuenta
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <footer class="bg-dark text-white text-center py-4">
            <h2 class="h5">TODOS LOS DERECHOS RESERVADOS</h2>
            <p class="small mb-0">© 2025 ALIMOP. Todos los derechos reservados.</p>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js"></script>
    <script src="/JS/perfil.js"></script>
</body>
</html>
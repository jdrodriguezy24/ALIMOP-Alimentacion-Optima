<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mis Productos - ALIMOP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/img/Logo/Logo.png">
</head>
<body>
    <div class="container-fluid p-0">
        <!-- Navbar -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark py-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" href="/inicioProveedor/<%= user.id %>">
                    <img src="/img/Logo/Logo.png" alt="logo" height="40" class="me-3">
                    <span class="fs-4 fw-bold">ALIMOP</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><a class="nav-link px-3 py-2" href="/inicioProveedor/<%= user.id %>"><i class="fas fa-home"></i> Inicio</a></li>
                        <li class="nav-item"><a class="nav-link px-3 py-2" href="/perfilProveedor/<%= user.id %>"><i class="fas fa-user"></i> Perfil</a></li>
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Contenido principal -->
        <div class="container my-5">
            <div class="row">
                <div class="col-12">
                    <h1 class="mb-4">Mis Productos Activos</h1>

                    <div class="card border-0 shadow">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th>Producto</th>
                                        <th>Precio</th>
                                        <th>Stock Disponible</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (productos && productos.length > 0) { %>
                                        <% productos.forEach((prod) => { %>
                                            <tr>
                                                <td><strong><%= prod.nombre %></strong></td>
                                                <td>$<%= parseFloat(prod.ValorUnidad).toLocaleString('es-CO') %></td>
                                                <td>
                                                    <% if (prod.cantidad < 10) { %>
                                                        <span class="badge bg-danger"><%= prod.cantidad %> unidades</span>
                                                    <% } else if (prod.cantidad < 25) { %>
                                                        <span class="badge bg-warning"><%= prod.cantidad %> unidades</span>
                                                    <% } else { %>
                                                        <span class="badge bg-success"><%= prod.cantidad %> unidades</span>
                                                    <% } %>
                                                </td>
                                                <td>
                                                    <a href="/reabastecer/<%= prod.idAlimento %>/<%= user.id %>" class="btn btn-sm btn-outline-primary">
                                                        <i class="fas fa-plus"></i> Reabastecer
                                                    </a>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="4" class="text-center text-muted py-4">
                                                <i class="fas fa-box-open fa-2x mb-2"></i>
                                                <p>No tienes productos activos</p>
                                                <a href="/agregarProducto/<%= user.id %>" class="btn btn-sm btn-primary">Agregar Producto</a>
                                            </td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="mt-4">
                        <a href="/inicioProveedor/<%= user.id %>" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i> Volver al Panel
                        </a>
                        <a href="/agregarProducto/<%= user.id %>" class="btn btn-primary">
                            <i class="fas fa-plus me-2"></i> Agregar Nuevo Producto
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <footer class="bg-dark text-white text-center py-4 mt-5">
            <p class="small mb-0">ALIMOP.com S.A.S. © 2024. Todos los derechos reservados</p>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

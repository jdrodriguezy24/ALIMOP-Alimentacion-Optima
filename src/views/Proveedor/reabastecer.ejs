<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reabastecer Producto - ALIMOP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/img/Logo/Logo.png">
</head>
<body>
    <div class="container-fluid p-0">
        <!-- Navbar -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark py-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" href="/inicioProveedor/<%= user.id %>">
                    <img src="/img/Logo/Logo.png" alt="logo" height="40" class="me-3">
                    <span class="fs-4 fw-bold">ALIMOP</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><a class="nav-link px-3 py-2" href="/inicioProveedor/<%= user.id %>"><i class="fas fa-home"></i> Inicio</a></li>
                        <li class="nav-item"><a class="nav-link px-3 py-2" href="/perfilProveedor/<%= user.id %>"><i class="fas fa-user"></i> Perfil</a></li>
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Contenido principal -->
        <div class="container my-5">
            <div class="row justify-content-center">
                <div class="col-lg-6">
                    <h1 class="mb-4">Reabastecer Producto</h1>

                    <% if (error) { %>
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i><%= error %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    <% } %>

                    <div class="card border-0 shadow mb-4">
                        <div class="card-body p-4">
                            <h5 class="card-title"><%= producto.nombre %></h5>
                            <hr>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <p class="text-muted mb-1">Stock Actual</p>
                                    <h3 class="text-primary"><%= producto.cantidad %> unidades</h3>
                                </div>
                                <div class="col-md-6">
                                    <p class="text-muted mb-1">Precio</p>
                                    <h3 class="text-success">$<%= parseFloat(producto.ValorUnidad).toLocaleString('es-CO') %></h3>
                                </div>
                            </div>
                        </div>
                    </div>

                    <form action="/reabastecer/<%= producto.idAlimento %>/<%= user.id %>" method="POST" class="card border-0 shadow">
                        <div class="card-body p-4">
                            <div class="mb-3">
                                <label for="cantidadAgregar" class="form-label">Cantidad a Agregar *</label>
                                <input type="number" class="form-control form-control-lg" id="cantidadAgregar" name="cantidadAgregar" required min="1" placeholder="Ingresa la cantidad">
                            </div>

                            <div class="alert alert-info">
                                <p class="mb-0"><strong>Stock después del reabastecimiento:</strong></p>
                                <p class="mb-0" id="stockPreview"><%= producto.Cantidad %> unidades</p>
                            </div>

                            <div class="d-grid gap-2 d-sm-flex justify-content-sm-end">
                                <a href="/inicioProveedor/<%= user.id %>" class="btn btn-outline-secondary">Cancelar</a>
                                <button type="submit" class="btn btn-success btn-lg">Confirmar Reabastecimiento</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <footer class="bg-dark text-white text-center py-4 mt-5">
            <p class="small mb-0">ALIMOP.com S.A.S. © 2024. Todos los derechos reservados</p>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const stockActual = <%= producto.cantidad %>;
        const inputCantidad = document.getElementById('cantidadAgregar');
        const stockPreview = document.getElementById('stockPreview');

        inputCantidad.addEventListener('input', function() {
            const cantidad = parseInt(this.value) || 0;
            const nuevoStock = stockActual + cantidad;
            stockPreview.textContent = nuevoStock + ' unidades';
        });
    </script>
</body>
</html>

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detalle de Orden - ALIMOP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/img/Logo/Logo.png">
</head>
<body>
    <div class="container-fluid p-0">
        <!-- Navbar -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark py-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" href="/inicioProveedor/<%= user.id %>">
                    <img src="/img/Logo/Logo.png" alt="logo" height="40" class="me-3">
                    <span class="fs-4 fw-bold">ALIMOP</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><a class="nav-link px-3 py-2" href="/inicioProveedor/<%= user.id %>"><i class="fas fa-home"></i> Inicio</a></li>
                        <li class="nav-item"><a class="nav-link px-3 py-2" href="/misOrdenes/<%= user.id %>"><i class="fas fa-list"></i> Mis Órdenes</a></li>
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Contenido principal -->
        <div class="container my-5">
            <div class="row">
                <div class="col-lg-8 mx-auto">
                    <h1 class="mb-4">Detalle de Orden #ORD<%= orden.idFacturaVenta %></h1>

                    <!-- Información de la orden -->
                    <div class="card border-0 shadow mb-4">
                        <div class="card-body p-4">
                            <div class="row">
                                <div class="col-md-6">
                                    <h5 class="text-muted">Información General</h5>
                                    <p class="mb-1"><strong>ID Orden:</strong> #ORD<%= orden.idFacturaVenta %></p>
                                    <p class="mb-1"><strong>Fecha:</strong> <%= orden.Fecha %></p>
                                    <p class="mb-0"><strong>Estado:</strong> <span class="badge bg-success">Completada</span></p>
                                </div>
                                <div class="col-md-6">
                                    <h5 class="text-muted">Información del Cliente</h5>
                                    <p class="mb-1"><strong>Cliente:</strong> <%= orden.nombreUsuario %></p>
                                    <p class="mb-1"><strong>Email:</strong> <a href="mailto:<%= orden.correo %>"><%= orden.correo %></a></p>
                                    <p class="mb-0"><strong>Teléfono:</strong> <%= orden.telefono %></p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Detalles del producto -->
                    <div class="card border-0 shadow mb-4">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Producto Ordenado</h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="row align-items-center">
                                <div class="col-md-6">
                                    <h6 class="text-muted">Producto</h6>
                                    <h4><%= orden.nombre %></h4>
                                </div>
                                <div class="col-md-3">
                                    <h6 class="text-muted">Cantidad</h6>
                                    <h4><%= orden.cantidad %> unidades</h4>
                                </div>
                                <div class="col-md-3">
                                    <h6 class="text-muted">Precio Unitario</h6>
                                    <h4>$<%= parseFloat(orden.ValorUnidad).toLocaleString('es-CO') %></h4>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Resumen de pago -->
                    <div class="card border-0 shadow mb-4">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Resumen de Pago</h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="row text-end">
                                <div class="col-md-8 text-start">
                                    <p class="mb-2"><strong>Subtotal:</strong></p>
                                    <p class="mb-2"><strong>Impuestos:</strong></p>
                                    <p class="mb-0"><strong>Total:</strong></p>
                                </div>
                                <div class="col-md-4">
                                    <p class="mb-2">$<%= parseFloat(orden.ValorTotal * 0.81).toLocaleString('es-CO') %></p>
                                    <p class="mb-2">$<%= parseFloat(orden.ValorTotal * 0.19).toLocaleString('es-CO') %></p>
                                    <p class="mb-0"><strong class="text-success fs-5">$<%= parseFloat(orden.ValorTotal).toLocaleString('es-CO') %></strong></p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Botones de acción -->
                    <div class="d-grid gap-2 d-sm-flex justify-content-sm-between">
                        <a href="/misOrdenes/<%= user.id %>" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-arrow-left me-2"></i> Volver a Órdenes
                        </a>
                        <a href="/inicioProveedor/<%= user.id %>" class="btn btn-primary btn-lg">
                            <i class="fas fa-home me-2"></i> Ir al Panel
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <footer class="bg-dark text-white text-center py-4 mt-5">
            <p class="small mb-0">ALIMOP.com S.A.S. © 2024. Todos los derechos reservados</p>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

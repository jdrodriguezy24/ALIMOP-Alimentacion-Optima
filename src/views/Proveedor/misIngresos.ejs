<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mis Ingresos - ALIMOP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/img/Logo/Logo.png">
</head>
<body>
    <div class="container-fluid p-0">
        <!-- Navbar -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark py-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" href="/inicioProveedor/<%= user.id %>">
                    <img src="/img/Logo/Logo.png" alt="logo" height="40" class="me-3">
                    <span class="fs-4 fw-bold">ALIMOP</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><a class="nav-link px-3 py-2" href="/inicioProveedor/<%= user.id %>"><i class="fas fa-home"></i> Inicio</a></li>
                        <li class="nav-item"><a class="nav-link px-3 py-2" href="/perfilProveedor/<%= user.id %>"><i class="fas fa-user"></i> Perfil</a></li>
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Contenido principal -->
        <div class="container my-5">
            <div class="row">
                <div class="col-12">
                    <h1 class="mb-4">Mis Ingresos</h1>

                    <div class="card border-0 shadow">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th>Período</th>
                                        <th>Ingresos Totales</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (ingresos && ingresos.length > 0) { %>
                                        <% let totalGeneral = 0; %>
                                        <% ingresos.forEach((ingreso) => { %>
                                            <% totalGeneral += parseFloat(ingreso.total || 0); %>
                                            <tr>
                                                <td><strong><%= new Date(ingreso.mes + '-01').toLocaleDateString('es-CO', { month: 'long', year: 'numeric' }) %></strong></td>
                                                <td class="text-success"><h5 class="mb-0">$<%= parseFloat(ingreso.total || 0).toLocaleString('es-CO') %></h5></td>
                                            </tr>
                                        <% }); %>
                                        <tr class="table-active">
                                            <td><strong>Total General</strong></td>
                                            <td class="text-success"><h5 class="mb-0">$<%= totalGeneral.toLocaleString('es-CO') %></h5></td>
                                        </tr>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="2" class="text-center text-muted py-4">
                                                <i class="fas fa-chart-line fa-2x mb-2"></i>
                                                <p>No hay ingresos registrados</p>
                                            </td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <% if (ingresos && ingresos.length > 0) { %>
                        <div class="mt-4 p-3 bg-light rounded">
                            <h5>Información de Ingresos</h5>
                            <p class="mb-1"><i class="fas fa-info-circle text-info me-2"></i> Los ingresos se calculan basados en las ventas completadas.</p>
                            <p class="mb-1"><i class="fas fa-info-circle text-info me-2"></i> Los datos se actualizan diariamente.</p>
                            <p class="mb-0"><i class="fas fa-info-circle text-info me-2"></i> Para más detalles de órdenes, visita la sección de "Mis Órdenes".</p>
                        </div>
                    <% } %>

                    <div class="mt-4">
                        <a href="/inicioProveedor/<%= user.id %>" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i> Volver al Panel
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <footer class="bg-dark text-white text-center py-4 mt-5">
            <p class="small mb-0">ALIMOP.com S.A.S. © 2024. Todos los derechos reservados</p>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mis Reseñas - ALIMOP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/img/Logo/Logo.png">
</head>
<body>
    <div class="container-fluid p-0">
        <!-- Navbar -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark py-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" href="/inicioProveedor/<%= user.id %>">
                    <img src="/img/Logo/Logo.png" alt="logo" height="40" class="me-3">
                    <span class="fs-4 fw-bold">ALIMOP</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><a class="nav-link px-3 py-2" href="/inicioProveedor/<%= user.id %>"><i class="fas fa-home"></i> Inicio</a></li>
                        <li class="nav-item"><a class="nav-link px-3 py-2" href="/perfilProveedor/<%= user.id %>"><i class="fas fa-user"></i> Perfil</a></li>
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Contenido principal -->
        <div class="container my-5">
            <div class="row">
                <div class="col-12">
                    <h1 class="mb-4">Mis Reseñas y Calificaciones</h1>

                    <% if (resenas && resenas.length > 0) { %>
                        <div class="row g-4">
                            <% resenas.forEach((resena) => { %>
                                <div class="col-lg-6">
                                    <div class="card border-0 shadow">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start mb-3">
                                                <div>
                                                    <h5 class="card-title"><%= resena.nombre %></h5>
                                                    <div class="text-warning">
                                                        <% for (let i = 0; i < resena.Nivel; i++) { %>
                                                            <i class="fas fa-star"></i>
                                                        <% } %>
                                                        <% for (let i = resena.Nivel; i < 5; i++) { %>
                                                            <i class="far fa-star"></i>
                                                        <% } %>
                                                    </div>
                                                </div>
                                                <small class="text-muted"><%= resena.Fecha %></small>
                                            </div>
                                            <% if (resena.Comentario) { %>
                                                <p class="card-text text-muted"><i class="fas fa-quote-left me-2 text-secondary"></i><%= resena.Comentario %></p>
                                            <% } else { %>
                                                <p class="card-text text-muted"><em>Sin comentario</em></p>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <div class="text-center py-5">
                            <i class="fas fa-star fa-5x text-muted mb-3"></i>
                            <h4>No tienes reseñas aún</h4>
                            <p class="text-muted">Las reseñas de tus clientes aparecerán aquí</p>
                        </div>
                    <% } %>

                    <div class="mt-4">
                        <a href="/inicioProveedor/<%= user.id %>" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i> Volver al Panel
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <footer class="bg-dark text-white text-center py-4 mt-5">
            <p class="small mb-0">ALIMOP.com S.A.S. © 2024. Todos los derechos reservados</p>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

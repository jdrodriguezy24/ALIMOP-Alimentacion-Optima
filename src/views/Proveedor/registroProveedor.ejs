<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro de Proveedor - ALIMOP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/CSS/styleProveedor/registroProveedor.css">
    <link rel="icon" type="image/png" href="./img/Logo/Logo.png">
</head>
<body>
    <div class="container-fluid p-0 registro-proveedor-wrapper">
        <header class="bg-light py-3 border-bottom">
            <div class="container d-flex justify-content-between align-items-center">
                <h1 class="h3 mb-0">Registro de Proveedor</h1>
                <a href="/" class="btn btn-outline-primary">Volver a Inicio</a>
            </div>
        </header>
        
        <main class="d-flex align-items-center justify-content-center">
            <section class="w-100">
                <div class="row justify-content-center">
                    <div class="col-md-8 col-lg-6">
                        <div class="card shadow-sm">
                            <div class="card-body p-5">
                                <h2 class="card-title text-center mb-2">Registra tu tienda</h2>
                                <p class="text-center text-muted mb-4 form-description">Llene los siguientes campos para el registro de tu tienda</p>
                                
                                <form class="registro-form" action="/registroProveedor" method="POST">
                                    <div class="mb-3 form-group">
                                        <label for="Regnombre" class="form-label">Nombre del Propietario</label>
                                        <input type="text" id="Regnombre" name="Regnombre" class="form-control" placeholder="Ingresa el nombre del propietario" required>
                                    </div>
                                    
                                    <div class="mb-3 form-group">
                                        <label for="Regemail" class="form-label">Correo Electrónico</label>
                                        <input type="email" id="Regemail" name="Regemail" class="form-control" placeholder="Ingresa un correo electrónico" required>
                                    </div>
                                    
                                    <div class="mb-3 form-group">
                                        <label for="Regpassword" class="form-label">Contraseña</label>
                                        <input type="password" id="Regpassword" name="Regpassword" class="form-control" placeholder="Ingresa una contraseña" required>
                                        <div class="input-group">
                                            <button type="button" class="btn btn-outline-secondary toggle-password" data-target="Regpassword">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                        </div>
                                    </div>
                                    
                                    <div class="mb-3 form-group">
                                        <label for="nombreEstablecimiento" class="form-label">Nombre del Establecimiento</label>
                                        <input type="text" id="nombreEstablecimiento" name="nombreEstablecimiento" class="form-control" placeholder="Nombre del establecimiento" required>
                                    </div>
                                    
                                    <div class="mb-3 form-group">
                                        <label for="direccionEstablecimiento" class="form-label">Dirección del Establecimiento</label>
                                        <input type="text" id="direccionEstablecimiento" name="direccionEstablecimiento" class="form-control" placeholder="Dirección del establecimiento" required>
                                    </div>
                                    
                                    <div class="mb-4 form-group">
                                        <label for="telefonoEstablecimiento" class="form-label">Teléfono del Establecimiento</label>
                                        <input type="tel" id="telefonoEstablecimiento" name="telefonoEstablecimiento" class="form-control" placeholder="Teléfono del establecimiento" required>
                                    </div>
                                    
                                    <button type="submit" class="btn btn-success w-100 mb-3">Registrar</button>
                                    
                                    <p class="text-center">¿Ya tienes tu tienda registrada? <a href="/login" class="text-decoration-none">Inicia sesión aquí</a></p>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <footer class="bg-dark text-white text-center py-4">
            <h2 class="h5">TODOS LOS DERECHOS RESERVADOS</h2>
            <p class="small mb-0">© 2025 ALIMOP. Todos los derechos reservados.</p>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="/JS/Proveedor/animacionRegistro.js"></script>
    <script src="/JS/script.js"></script>
</body>
</html>